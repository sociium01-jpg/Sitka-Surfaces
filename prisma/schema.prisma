datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Encrypted password
  role      String   // "ADMIN", "EDITOR", "VIEWER"
  createdAt DateTime @default(now())
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String
  company      String?
  interestArea String   // "ALL", "PLYWOOD", "LAMINATES", "VENEER", "DECORATIVES"
  persona      String   // "ARCHITECT", "DESIGNER", "CONTRACTOR", "DEALER", "HOMEOWNER", "OTHER"
  createdAt    DateTime @default(now())
  utmSource    String?
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  vertical    String   // "PLYWOOD", "LAMINATES", "VENEER", "DECORATIVES"
  category    String   // e.g., "MR Grade", "High Gloss", "Natural Wood"
  description String
  specs       String   // JSON string representing technical specs
  swatches    String   // JSON string representing swatches (name, color/image, etc.)
  applications String  // Comma-separated list or JSON array of applications
  tags        String?  // Comma-separated list or JSON array of tags
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Post {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  category    String   // "Material Guides", "Sustainability", "Design Trends", etc.
  summary     String
  content     String   // Markdown content
  author      String
  publishedAt DateTime @default(now())
  status      String   // "DRAFT", "PUBLISHED"
}

model Testimonial {
  id        String   @id @default(uuid())
  quote     String
  name      String
  role      String
  company   String
  vertical  String   // "Plywood", "Laminates", etc., or "General"
  persona   String   // "Architect", "Designer", etc.
  approved  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model PageContent {
  id        String   @id @default(uuid())
  page      String   // "home", "about", etc.
  section   String   // e.g., "hero", "manifesto"
  key       String   // e.g., "headline", "body"
  value     String   // The text content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([page, section, key])
}

model HeroMedia {
  id          String   @id @default(uuid())
  page        String   @unique // "home", "plywood", "laminates", "veneer", "decoratives", "about", "inspiration"
  mediaType   String   // "image" or "video"
  mediaUrl    String   // URL or local path
  fallbackUrl String? // Image fallback for videos
  createdAt   DateTime @default(now())
}

model VisualizerScene {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  roomImage       String
  naturalWidth    Int              @default(1024)
  naturalHeight   Int              @default(1024)
  status          String           // "DRAFT", "PUBLISHED"
  displayOrder    Int              @default(0)
  whereShown      String           // Comma-separated or JSON string array
  overlaySettings String           // JSON settings
  zones           VisualizerZone[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model VisualizerZone {
  id                String          @id @default(uuid())
  sceneId           String
  scene             VisualizerScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  label             String
  mask              String?
  shadingLayer      String?
  corners           String          // JSON array of corners
  allowedCategories String          // JSON array of category names
  defaultFinishId   String?
  defaultFinish     Finish?         @relation(fields: [defaultFinishId], references: [id])
  widthCm           Float?
  heightCm          Float?
  displayOrder      Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model FinishCategory {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  displayOrder     Int      @default(0)
  defaultEdgeStyle String   @default("flatSolid") // "layeredPly" | "flatSolid" | "custom"
  defaultRoughness Float    @default(0.5)
  defaultMetalness Float    @default(0.0)
  finishes         Finish[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Finish {
  id              String          @id @default(uuid())
  name            String
  sku             String          @unique
  specLine        String
  categoryId      String
  category        FinishCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  status          String          // "ACTIVE", "DISCONTINUED", "COMING_SOON"
  thumbnailImage  String
  tileableTexture String
  pbrMaps         String?         // JSON settings
  materialType    String          // "matte", "gloss", "satin", "wood", "stone"
  tags            String          // Comma-separated or JSON
  color           String?
  tileWidthCm     Float?
  tileHeightCm    Float?
  modelType       String          @default("generated") // "generated" | "uploadedModel"
  modelAsset      String?
  autoNormalMap   String?
  realWidthMm     Float?          @default(1220)
  realHeightMm    Float?          @default(2440)
  realThicknessMm Float?          @default(18)
  roughness       Float?
  metalness       Float?
  defaultZones    VisualizerZone[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
